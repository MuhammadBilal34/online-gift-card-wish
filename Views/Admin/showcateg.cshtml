@model IEnumerable<mytheme.Models.Categ>

@{
    ViewData["Title"] = "showcateg";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>showcateg</h1>

<p>
    <a asp-action="Createcateg">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Namee)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Namee)
            </td>
            <td>
                    <a asp-action="EditCateg" asp-route-id="@item.Id">Edit</a> |
                
                    <a asp-action="Deletecateg" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
