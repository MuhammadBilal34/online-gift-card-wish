@using System.Security.Claims;
@{
    mytheme.Models.StudentdbContext db = new mytheme.Models.StudentdbContext();
    string myrole = User.FindFirst(ClaimTypes.Role)?.Value;
    bool isLoggedIn = User.Identity.Name != null;
}

<nav class="navbar navbar-expand-lg navbar-dark ftco_navbar bg-dark ftco-navbar-light" id="ftco-navbar">
    <div class="container">
        <a class="navbar-brand" href="/">E-Greetings</a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#ftco-nav"
                aria-controls="ftco-nav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="oi oi-menu"></span> Menu
        </button>

        <div class="collapse navbar-collapse" id="ftco-nav">
            <ul class="navbar-nav ml-auto">
                <li class="nav-item active"><a href="/" class="nav-link">Home</a></li>
            
              

                @* Dynamically show categories from database *@
                @foreach (var item in db.Categs.ToList())
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-action="showproducts" asp-controller="Client" asp-route-id="@item.Id">
                            @item.Namee
                        </a>
                    </li>
                }

                @* Dropdown for Portfolio *@
               

              

              
               

     
                @if (isLoggedIn)
                {
                    <li class="nav-item"><a href="/Cookies/Profile" class="nav-link">Profile</a></li>
                    <li class="nav-item"><a href="/Client/Profile" class="nav-link">My Uploads</a></li>
                    <li class="nav-item"><a href="/Cookies/logout" class="nav-link">Logout</a></li>
                }
                else
                {
                    <li class="nav-item"><a href="/Cookies/login" class="nav-link">Login</a></li>
                    <li class="nav-item"><a href="/Cookies/registration" class="nav-link">Signup</a></li>
                }

              
            </ul>
        </div>
    </div>
</nav>
